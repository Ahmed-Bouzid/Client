{
  "expo": {
    "name": "SunnyGo",
    "slug": "sunnygo-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF8C42"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FF8C42"
      },
      "package": "com.warai.sunnygoclient"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/icon.png",
      "name": "SunnyGo",
      "shortName": "SunnyGo",
      "description": "Commandez directement depuis votre table",
      "themeColor": "#FF8C42",
      "backgroundColor": "#FFFFFF",
      "lang": "fr",
      "scope": "/",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "e842aaae-163a-4142-a561-3d7a128c5ce1"
      }
    }
  }
}
